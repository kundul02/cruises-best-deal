# Vacations To Go — email-only login (Go, без пароля)
VTG_EMAIL=your@email.com

# Navimba forum (https://navimba.com/) — npm run navimba-login
# NAVIMBA_USER=
# NAVIMBA_PASS=

# Optional: only if you expose price-server via public tunnel and want a password
# REFRESH_TOKEN=

# Optional: override EUR/USD for best-price comparison
# EUR_USD_RATE=1.08

# price-server port (default 3920)
# PRICE_SERVER_PORT=3920
